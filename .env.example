# --- Database (matches docker-compose) ---
# Admin/owner role: used by migrations to create tables, roles, grants and RLS.
POSTGRES_USER=mfp
POSTGRES_PASSWORD=mfp_dev_password
POSTGRES_DB=mfp
DATABASE_ADMIN_URL=postgres://mfp:mfp_dev_password@localhost:5432/mfp

# Restricted app role: used by the API at runtime so Row-Level Security applies.
# (created on first DB init by docker/postgres/init/01-create-app-role.sh)
APP_DB_USER=app
APP_DB_PASSWORD=app_dev_password
DATABASE_URL=postgres://app:app_dev_password@localhost:5432/mfp

# --- API ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# --- Auth (use strong, unique secrets outside local dev) ---
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
